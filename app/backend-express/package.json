{
  "name": "convertalps-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Sidecar Express — ConvertAlps FAO Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "pkg": "npm run build && pkg dist/workerEntry.js --targets node20-win-x64,node20-linux-x64,node20-mac-x64 --output ../src-tauri/binaries/backend-server",
    "pkg:win": "npm run build && pkg dist/workerEntry.js --targets node20-win-x64 --output ../src-tauri/binaries/backend-server-x86_64-pc-windows-msvc.exe",
    "pkg:win:dev": "npm run build && pkg dist/workerEntry.js --targets node20-win-x64 --output ../backend-sidecar/backend-server-x86_64-pc-windows-msvc.exe"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "cors": "^2.8.5",
    "dxf": "^4.5.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@yao-pkg/pkg": "^5.12.0",
    "jest": "^30.4.2",
    "prisma": "^5.17.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  },
  "pkg": {
    "assets": [
      "node_modules/.prisma/client/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/prisma/build/**/*",
      "prisma/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  }
}
