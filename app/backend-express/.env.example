# ConvertAlps Backend — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# ── Serveur ────────────────────────────────────────────────────────────────────
CONVERTALPS_PORT=3737
NODE_ENV=development

# ── Base de données PostgreSQL (mode connecté usine) ─────────────────────────
DATABASE_URL="postgresql://convertalps:password@localhost:5432/convertalps_db?schema=public"

# ── Fallback SQLite (mode déconnecté / hors-ligne) ────────────────────────────
# Activé automatiquement si PostgreSQL est inaccessible
SQLITE_FALLBACK_PATH="./data/convertalps_local.db"

# ── Sécurité ───────────────────────────────────────────────────────────────────
# Clé secrète pour la signature des audit logs (HMAC-SHA256)
AUDIT_LOG_SECRET="CHANGEZ-MOI-EN-PRODUCTION-32-CHARS-MIN"
